<!DOCTYPE html>
<html lang="en" class="nhsuk-template">
  <head>
    <meta charset="utf-8" />
    <title>{% block pageTitle %}{{ title }}{% endblock %} — {{ serviceName }} (Prototype)</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#005eb8" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="stylesheet" href="/nhsuk-frontend/nhsuk-frontend.min.css" />
    <link rel="stylesheet" href="/public/css/app.css" />
  </head>
  <body class="nhsuk-template__body">
    <script>document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' nhsuk-frontend-supported' : '');</script>

    <a class="nhsuk-skip-link" href="#maincontent">Skip to main content</a>

    {% include "partials/prototype-banner.njk" %}
    {% include "partials/header.njk" %}

    <div class="nhsuk-width-container">
      {% block beforeContent %}{% endblock %}
      <main class="nhsuk-main-wrapper" id="maincontent" role="main">
        {% block content %}{% endblock %}
      </main>
    </div>

    {% include "partials/footer.njk" %}

    <script type="module" src="/public/js/init.mjs"></script>
  </body>
</html>
