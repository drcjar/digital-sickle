{
  "defaults": {
    "runners": ["axe"],
    "timeout": 30000,
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox"]
    }
  },
  "urls": [
    "http://localhost:3000/",
    "http://localhost:3000/login",
    "http://localhost:3000/register/patient",
    "http://localhost:3000/register/clinician",
    "http://localhost:3000/about",
    "http://localhost:3000/accessibility"
  ]
}
