<!DOCTYPE html>
<html lang="en" class="nhsuk-template">
  <head>
    <meta charset="utf-8" />
    <title>{{ title }} — {{ site.name }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#005eb8" />
    <meta name="description" content="{{ description or 'A personalised digital care plan for acute painful sickle cell crises — an NHS Race & Health Observatory project.' }}" />
    <link rel="stylesheet" href="{{ '/nhsuk-frontend/nhsuk-frontend.min.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/site.css' | url }}" />
  </head>
  <body class="nhsuk-template__body">
    <a class="nhsuk-skip-link" href="#maincontent">Skip to main content</a>

    <header class="nhsuk-header" role="banner">
      <div class="nhsuk-header__container nhsuk-width-container">
        <div class="nhsuk-header__logo">
          <a class="nhsuk-header__link" href="{{ '/' | url }}" aria-label="{{ site.name }} home">
            <span class="nhsuk-header__service-name">{{ site.name }}</span>
          </a>
        </div>
      </div>
      <nav class="nhsuk-navigation" aria-label="Primary navigation">
        <div class="nhsuk-width-container">
          <ul class="nhsuk-navigation__list" style="display:flex; flex-wrap:wrap; gap:1rem; list-style:none; padding:0.5rem 0; margin:0;">
            {% for item in site.nav %}
              <li><a class="nhsuk-navigation__link" href="{{ item.url | url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.text }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </nav>
    </header>

    <div class="nhsuk-width-container">
      <main class="nhsuk-main-wrapper" id="maincontent" role="main">
        <div class="nhsuk-grid-row">
          <div class="nhsuk-grid-column-three-quarters">
            {{ content | safe }}
          </div>
        </div>
      </main>
    </div>

    <footer role="contentinfo">
      <div class="nhsuk-footer-container">
        <div class="nhsuk-width-container">
          <div class="nhsuk-footer">
            <p class="nhsuk-body-s">A project of the <strong>{{ site.owner }}</strong>. Developed in the open.</p>
            <ul class="nhsuk-footer__list">
              {% for item in site.nav %}
                <li class="nhsuk-footer__list-item"><a class="nhsuk-footer__list-item-link" href="{{ item.url | url }}">{{ item.text }}</a></li>
              {% endfor %}
              <li class="nhsuk-footer__list-item"><a class="nhsuk-footer__list-item-link" href="{{ site.repoUrl }}">Source code</a></li>
            </ul>
            <p class="nhsuk-body-s">© {{ '' | year }} {{ site.owner }}. Code under the MIT Licence.</p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
